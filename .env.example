# Copy this file to .env and fill in your values.
# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model choice notes (learned the hard way — see scripts/diag_quota.py and
# the FALLBACK_MODELS lists in ingestion/ocr_transcriber.py and
# enrichment/contextualizer.py):
#  - OCR needs to READ rendered Bangla glyphs accurately. The full "flash"
#    models do this cleanly; the cheap "*-flash-lite" models garble Bangla
#    into romanized mojibake and sometimes loop, so they are NOT used for OCR.
#  - On a free-tier key, EVERY model name (gemini-2.5-flash,
#    gemini-flash-latest, gemini-2.5-flash-lite, gemini-flash-lite-latest)
#    is its own SEPARATE ~20 requests/DAY bucket. Each step's
#    FALLBACK_MODELS list tries a second model name to roughly double its
#    daily allowance. So a 271-page extraction + ~150 chunk enrichment
#    naturally spans MULTIPLE DAYS — both jobs are resumable, which is fine.
GEMINI_OCR_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_AUX_MODEL=gemini-2.5-flash-lite

# Local embedding / reranking models (downloaded on first use)
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# Retrieval tuning
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=5
RRF_K=60

# Chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
