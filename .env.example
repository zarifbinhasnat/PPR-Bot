# Copy this file to .env and fill in your values.
# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model aliases (Google remaps these to current recommended models, so we
# avoid hardcoding a dated model name like "gemini-2.5-flash" that may be
# retired later).
GEMINI_OCR_MODEL=gemini-flash-latest
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_AUX_MODEL=gemini-flash-latest

# Local embedding / reranking models (downloaded on first use)
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# Retrieval tuning
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=5
RRF_K=60

# Chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
